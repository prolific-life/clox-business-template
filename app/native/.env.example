# Public Supabase coordinates — the SAME project the web app uses. Both
# values are public by design (the anon key ships in the web JS bundle).
# Copy to `.env`; Expo inlines EXPO_PUBLIC_* at bundle time.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Your web app's URL (the SAME deployment as app/web — e.g. the staging
# https URL). Google sign-in redirects to ${EXPO_PUBLIC_APP_URL}/auth/native-finish,
# which mints the Supabase session via the Clox broker. REQUIRED for Google.
EXPO_PUBLIC_APP_URL=

# The Clox OAuth broker origin (runs Google with its shared OAuth app, so you
# need NO Google setup of your own). Leave as-is unless self-hosting Clox.
EXPO_PUBLIC_CLOX_BROKER_URL=https://www.clox.co
