node_modules/
.next/
.turbo/
dist/
build/
.DS_Store
*.log
*.tsbuildinfo
.env
.env.local
.env.*.local
.pnpm-store/

# Re-include lock file (parent core .gitignore excludes
# pnpm-lock.yaml globally). The template seed needs the
# lock for reproducible installs in spawned workspaces.
!pnpm-lock.yaml

# Exclude stray npm/yarn lockfiles. The template is a pnpm workspace; a
# leftover app/web/package-lock.json makes Vercel run `npm ci` against a
# stale tree (missing `next`) and fail Next.js detection. Both the deploy
# Action and the server-side native deploy install fresh from package.json.
package-lock.json
yarn.lock

# Marketing/pitch creative BINARIES are hosted on Supabase Storage, not
# committed (they bloat the repo + every Vercel deploy). Only the tiny
# JSON metadata sidecars next to them are tracked — they carry the
# public URL the UI reads. If a generator writes a binary here anyway,
# git ignores it.
marketing/campaigns/**/creatives/**/*.png
marketing/campaigns/**/creatives/**/*.jpg
marketing/campaigns/**/creatives/**/*.jpeg
marketing/campaigns/**/creatives/**/*.webp
marketing/campaigns/**/creatives/**/*.gif
marketing/campaigns/**/creatives/**/*.mp4
marketing/campaigns/**/creatives/**/*.webm
marketing/campaigns/**/creatives/**/*.mov
app/web/public/assets/marketing/**
