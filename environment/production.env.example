# Production env vars for the spawned business app.
# Real values land on the Vercel project's Environment
# Variables (Settings -> Environment Variables); this file
# documents the shape so the user (and Claude Code) know
# what's expected. The backend templates these in at
# workspace-creation / materialization time.

# --- Supabase (auth + DB) ---
# The app's auth + database. A Supabase project is
# provisioned per workspace at creation time; these two
# values come from the Supabase dashboard:
#   Project Settings -> Data API (or API):
#     - URL              -> NEXT_PUBLIC_SUPABASE_URL
#     - anon / public key -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# Both are PUBLIC (safe to expose in the browser bundle);
# the anon key is row-level-security gated, not a secret.
# NOTE: newer Supabase projects label the public key
# "publishable" (sb_publishable_...); it is the same value
# — drop it into NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — server-only, NEVER prefixed NEXT_PUBLIC
# and NEVER shipped to the browser. Used by automations /
# admin tasks that must bypass row-level security. From the
# same Supabase API settings page ("service_role" key).
SUPABASE_SERVICE_ROLE_KEY=

# --- OAuth providers (configured in Supabase, not here) ---
# Google (and any other) OAuth client ID + secret are set in
# the Supabase dashboard, NOT in app env:
#   Authentication -> Providers -> Google -> enable, then
#   paste the Google Cloud OAuth 2.0 Client ID + Secret.
# Also add the app's callback to the provider + Supabase:
#   - Supabase: Authentication -> URL Configuration ->
#       Redirect URLs: add  https://<your-domain>/auth/callback
#       (and http://localhost:3000/auth/callback for local).
#   - Google Cloud: Authorized redirect URI ->
#       https://<project-ref>.supabase.co/auth/v1/callback
# The two vars below are OPTIONAL — only needed if you
# script provider config via the Supabase Management API
# at materialization time instead of the dashboard.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- App ---
# Canonical public URL of the deployed app (the Vercel
# production domain, e.g. https://acme.com). Used for
# absolute links + OAuth redirect construction fallbacks.
WEB_APP_URL=

# --- Deploy ---
# Vercel personal/team API token. Set on the deploy side
# (Composio Vercel account or CI), not consumed by the app
# at runtime. Auto-deploy itself needs NO token — it runs
# off the native Vercel<->GitHub Git integration on every
# push to the production branch (see README "Auto-deploy").
VERCEL_API_KEY=

# --- LLM ---
ANTHROPIC_API_KEY=

# --- Bound external accounts (Composio connected_account_ids) ---
# v9 sets these at materialization time; the automations
# cron + skills route their Composio calls through these
# accounts.
DEFAULT_VERCEL_COMPOSIO_ACCOUNT_ID=
DEFAULT_EMAIL_COMPOSIO_ACCOUNT_ID=
DEFAULT_EMAIL_TOOLKIT=
